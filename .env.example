# Checkmate Arena — environment variables (example)
# Copy to .env.local and fill with real values. Never commit .env.local.
# .env*.local is gitignored; .env.example (this file) is safe to commit.

# --- Supabase (Stage 3.2 auth layer) -------------------------------------

# Project URL. Supabase dashboard -> Project Settings -> API -> Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key. Safe to expose to the browser; RLS is the real guard.
# Supabase dashboard -> Project Settings -> API -> Project API keys -> anon.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key. SERVER-ONLY. Bypasses RLS. Never expose to the browser,
# never prefix with NEXT_PUBLIC_. Use only in API routes / server code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- AI Coach (Stage 4.0A) -----------------------------------------------
# OpenAI-compatible API. SERVER-ONLY — never prefix with NEXT_PUBLIC_.
# Route: app/api/coach/route.ts  Prompt builder: lib/ai/coachPrompt.ts
#
# AI_COACH_API_BASE_URL — base URL without /chat/completions suffix.
#   OpenAI: https://api.openai.com/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Local (Ollama): http://localhost:11434/v1
AI_COACH_API_BASE_URL=

# API key for the chosen provider.
AI_COACH_API_KEY=

# Model name as accepted by the provider.
#   OpenAI: gpt-4o-mini
#   Anthropic (via OpenRouter): anthropic/claude-haiku-4-5
#   Ollama: llama3.2
AI_COACH_MODEL=
